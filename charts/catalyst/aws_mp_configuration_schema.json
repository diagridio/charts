{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Catalyst AWS Marketplace Configuration Schema",
  "description": "Schema for configuring Catalyst via AWS Marketplace / EKS Addon parameters.",
  "properties": {
    "join_token": {
      "type": "string",
      "description": "Join token obtained by creating a Region in Diagrid Cloud. Required for enrollment.",
      "minLength": 1
    },
    "agent": {
      "type": "object",
      "description": "Agent configuration.",
      "properties": {
        "existingJoinTokenSecret": {
          "type": "object",
          "description": "Reference to a pre-created Kubernetes Secret containing the join token. Alternative to providing join_token directly.",
          "properties": {
            "name": {
              "type": "string",
              "description": "Name of the existing Kubernetes Secret."
            },
            "key": {
              "type": "string",
              "default": "join_token",
              "description": "Key within the Secret that contains the join token."
            }
          }
        }
      }
    },
    "global": {
      "type": "object",
      "description": "Global parameters.",
      "properties": {
        "control_plane_url": {
          "type": "string",
          "description": "Control plane gRPC URL.",
          "examples": ["catalyst-cloud.r1.diagrid.io:443"]
        },
        "control_plane_http_url": {
          "type": "string",
          "description": "Control plane HTTP URL.",
          "examples": ["https://api.r1.diagrid.io"]
        },
        "secrets": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["kubernetes", "aws"],
              "default": "aws"
            },
            "aws": {
              "type": "object",
              "properties": {
                "region": {
                  "type": "string",
                  "description": "AWS region for Secrets Manager."
                }
              }
            }
          }
        }
      }
    }
  },
  "oneOf": [
    {
      "required": ["join_token"]
    },
    {
      "required": ["agent"],
      "properties": {
        "agent": {
          "required": ["existingJoinTokenSecret"],
          "properties": {
            "existingJoinTokenSecret": {
              "required": ["name"]
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
